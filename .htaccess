RewriteEngine On
# Options All -Indexes (Comentado porque InfinityFree y otros hostings gratuitos lo bloquean y causan Error 403)

RewriteCond %{REQUEST_URI} !\.(css|js|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$ [NC]

RewriteRule ^$ index.php [L]

RewriteRule ^([a-zA-Z0-9ñÑ-]+)/?([a-zA-Z0-9ñÑ-]+)?/?([a-zA-Z0-9ñÑ-]+)?$ index.php?url=$1&accion=$2&id=$3 [QSA,L]